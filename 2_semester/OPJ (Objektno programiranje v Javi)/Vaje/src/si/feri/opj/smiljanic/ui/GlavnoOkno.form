<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="si.feri.opj.smiljanic.ui.GlavnoOkno">
  <grid id="27dc6" binding="mainPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="18" width="683" height="504"/>
    </constraints>
    <properties>
      <background color="-12694152"/>
    </properties>
    <border type="none"/>
    <children>
      <grid id="ab097" binding="menuPanel" layout-manager="FlowLayout" hgap="10" vgap="5" flow-align="1">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="6af85" class="javax.swing.JButton" binding="gumbSportniki">
            <constraints/>
            <properties>
              <text value="Športniki"/>
              <verticalTextPosition value="0"/>
            </properties>
          </component>
          <component id="4f9fb" class="javax.swing.JButton" binding="gumbPrizorisca">
            <constraints/>
            <properties>
              <text value="Prizorišča"/>
            </properties>
          </component>
          <component id="94bb5" class="javax.swing.JButton" binding="gumbDogodki">
            <constraints/>
            <properties>
              <text value="Dogodki"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="cd9e7" binding="contentPanel" layout-manager="CardLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children/>
      </grid>
    </children>
  </grid>
</form>
